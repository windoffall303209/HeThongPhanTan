NODE_ENV=development

# Bootstrap server
BOOTSTRAP_PORT=3000
BOOTSTRAP_URL=http://127.0.0.1:3000
PEER_TTL_MS=30000

# Peer defaults. Override with npm run peer:a / peer:b / peer:c.
PEER_ID=peer-a
USERNAME=Alice
PEER_HOST=127.0.0.1
TCP_PORT=5101
WEB_PORT=3101

# MySQL. Keep DB_FALLBACK_MEMORY=true while developing if MySQL is not running.
DB_ENABLED=true
DB_FALLBACK_MEMORY=true
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=p2p_chat

# P2P behavior
TCP_TIMEOUT_MS=5000
SEND_RETRIES=2
HEARTBEAT_INTERVAL_MS=8000
PEER_SYNC_INTERVAL_MS=5000
OFFLINE_POLL_INTERVAL_MS=5000
MAX_FILE_BYTES=2097152

# Advanced feature: AES-256-GCM encryption on message content.
ENCRYPTION_ENABLED=true
P2P_SHARED_SECRET=change-this-secret-before-demo
