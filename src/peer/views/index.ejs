<!doctype html>
<html lang="vi">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= self.username %> — P2P Chat</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/public/styles.css" />
  </head>
  <body>
    <div id="app"
      data-peer-id="<%= self.peerId %>"
      data-username="<%= self.username %>"
      data-max-file-bytes="<%= maxFileBytes %>"
    >
      <!-- ===== LEFT SIDEBAR ===== -->
      <aside id="sidebar">
        <div id="my-info-card">
          <div class="my-avatar"><%= self.username[0].toUpperCase() %></div>
          <div class="my-details">
            <div class="my-name"><%= self.username %></div>
            <div class="my-id"><%= self.peerId %></div>
            <div class="my-meta">TCP:<%= self.tcpPort %> · Web:<%= self.webPort %><% if (encryptionEnabled) { %> · AES-256<% } %></div>
          </div>
          <span id="status-pill" class="status-pill online">Online</span>
        </div>
        <div id="sidebar-toolbar">
          <button id="sync-btn" class="toolbar-btn">Sync</button>
          <button id="churn-btn" class="toolbar-btn">Churn</button>
        </div>
        <div id="conv-tabs">
          <button class="conv-tab active" data-tab="direct">Trực tiếp</button>
          <button class="conv-tab" data-tab="group">Nhóm</button>
        </div>
        <div id="conv-list">
          <div id="pane-direct" class="conv-pane">
            <div id="peer-conv-list"></div>
            <div class="conv-item" id="broadcast-conv-item">
              <div class="conv-avatar" style="background:#fff3cd;font-size:18px">📢</div>
              <div class="conv-info">
                <div class="conv-name">Broadcast</div>
                <div class="conv-sub">Gửi tới tất cả peer</div>
              </div>
            </div>
          </div>
          <div id="pane-group" class="conv-pane" style="display:none">
            <div id="group-conv-list"></div>
          </div>
        </div>
        <div id="stats-bar">
          <div class="stat-cell"><span id="stat-sent">0</span><span class="stat-label">Gửi</span></div>
          <div class="stat-cell"><span id="stat-delivered">0</span><span class="stat-label">Đến</span></div>
          <div class="stat-cell"><span id="stat-failed">0</span><span class="stat-label">Lỗi</span></div>
          <div class="stat-cell"><span id="stat-queued">0</span><span class="stat-label">Chờ</span></div>
        </div>
      </aside>

      <!-- ===== CENTER CHAT ===== -->
      <main id="chat-main">
        <div id="chat-header">
          <div id="chat-header-avatar"></div>
          <div id="chat-header-info">
            <div id="chat-title">Chọn một cuộc trò chuyện</div>
            <div id="chat-subtitle">Chọn peer hoặc nhóm từ thanh bên</div>
          </div>
        </div>
        <div id="messages-area">
          <div id="empty-chat-state">
            <div class="empty-icon">💬</div>
            <div class="empty-title">Chưa có cuộc trò chuyện</div>
            <div class="empty-desc">Chọn một peer từ danh sách bên trái để bắt đầu.</div>
          </div>
          <div id="message-list" class="message-list" style="display:none"></div>
        </div>
        <div id="composer-area">
          <form id="composer-direct" class="composer-form" style="display:none">
            <div class="cpill">
              <button type="button" id="composer-plus-btn" class="cpill-plus" title="Đính kèm file">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              </button>
              <input type="file" id="file-input" style="display:none" />
              <div id="file-chip" class="file-chip" style="display:none">
                <span id="file-name-display"></span>
                <button type="button" id="clear-file-btn" class="file-chip-clear">
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                </button>
              </div>
              <textarea id="direct-content" rows="1" placeholder="Nhập tin nhắn..."></textarea>
              <button type="submit" class="cpill-send">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="19" x2="12" y2="5"/><polyline points="5 12 12 5 19 12"/></svg>
              </button>
            </div>
          </form>
          <form id="composer-group" class="composer-form" style="display:none">
            <div class="cpill">
              <textarea id="group-content" rows="1" placeholder="Nhắn tin nhóm..."></textarea>
              <button type="submit" class="cpill-send">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="19" x2="12" y2="5"/><polyline points="5 12 12 5 19 12"/></svg>
              </button>
            </div>
          </form>
          <form id="composer-broadcast" class="composer-form" style="display:none">
            <div class="cpill">
              <textarea id="broadcast-content" rows="1" placeholder="Broadcast tới tất cả peer..."></textarea>
              <button type="submit" class="cpill-send" style="background:#f59e0b">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="19" x2="12" y2="5"/><polyline points="5 12 12 5 19 12"/></svg>
              </button>
            </div>
          </form>
        </div>
      </main>

      <!-- ===== RIGHT PANEL ===== -->
      <aside id="right-panel">
        <div class="rp-section">
          <div class="rp-header">
            <h3>Nhóm chat</h3>
            <button id="create-group-btn" class="rp-action-btn">+ Tạo</button>
          </div>
          <div id="groups-list"></div>
        </div>
        <div class="rp-section">
          <div class="rp-header">
            <h3>Mạng lưới</h3>
            <button id="invite-peer-btn" class="rp-action-btn">+ Mời</button>
          </div>
          <div id="network-list"></div>
        </div>
        <div class="rp-section rp-logs-section">
          <div class="rp-header">
            <h3>Nhật ký</h3>
            <button id="clear-logs-btn" class="rp-action-btn">Xóa</button>
          </div>
          <div id="log-list" class="log-list"></div>
        </div>
      </aside>
    </div>

    <!-- Modal: Forward Message -->
    <div id="modal-forward" class="modal-overlay" style="display:none">
      <div class="modal-box">
        <div class="modal-head"><h3>Chuyển tiếp tin nhắn</h3><button class="modal-close" data-modal="modal-forward">✕</button></div>
        <div class="modal-body">
          <p class="modal-desc">Chọn peer đích để gửi lại nội dung tin nhắn đã chọn.</p>
          <label class="form-label">Peer nhận</label>
          <select id="forward-peer-select" class="form-input"></select>
          <input type="hidden" id="forward-message-id" />
        </div>
        <div class="modal-foot">
          <button class="btn-modal-cancel" data-modal="modal-forward">Hủy</button>
          <button id="confirm-forward-send" class="btn-modal-ok">Chuyển tiếp</button>
        </div>
      </div>
    </div>

    <!-- Modal: Create Group -->
    <div id="modal-create-group" class="modal-overlay" style="display:none">
      <div class="modal-box">
        <div class="modal-head"><h3>Tạo nhóm mới</h3><button class="modal-close" data-modal="modal-create-group">✕</button></div>
        <div class="modal-body">
          <label class="form-label">Tên nhóm</label>
          <input id="new-group-name" type="text" placeholder="VD: Nhóm học tập" class="form-input" />
          <label class="form-label" style="margin-top:12px">Thành viên</label>
          <div id="new-group-members" class="member-checkbox-list"></div>
        </div>
        <div class="modal-foot">
          <button class="btn-modal-cancel" data-modal="modal-create-group">Hủy</button>
          <button id="confirm-create-group" class="btn-modal-ok">Tạo nhóm</button>
        </div>
      </div>
    </div>

    <!-- Modal: Add Members -->
    <div id="modal-add-members" class="modal-overlay" style="display:none">
      <div class="modal-box">
        <div class="modal-head"><h3>Thêm thành viên</h3><button class="modal-close" data-modal="modal-add-members">✕</button></div>
        <div class="modal-body">
          <label class="form-label">Peer IDs (phân cách bằng dấu phẩy)</label>
          <input id="add-members-input" type="text" placeholder="peer-x, peer-y" class="form-input" />
          <input type="hidden" id="add-members-group-id" />
        </div>
        <div class="modal-foot">
          <button class="btn-modal-cancel" data-modal="modal-add-members">Hủy</button>
          <button id="confirm-add-members" class="btn-modal-ok">Thêm</button>
        </div>
      </div>
    </div>

    <!-- Modal: Invite Peer -->
    <div id="modal-invite-peer" class="modal-overlay" style="display:none">
      <div class="modal-box">
        <div class="modal-head"><h3>Mời peer mới</h3><button class="modal-close" data-modal="modal-invite-peer">✕</button></div>
        <div class="modal-body">
          <p class="modal-desc">Peer mới sẽ đăng ký qua <strong>peer này</strong> như introducer.</p>
          <label class="form-label">Peer ID</label>
          <input id="invite-peer-id" type="text" placeholder="peer-x" class="form-input" />
          <label class="form-label" style="margin-top:10px">Tên hiển thị</label>
          <input id="invite-username" type="text" placeholder="Alice" class="form-input" />
          <div class="form-row-2" style="margin-top:10px">
            <div><label class="form-label">TCP Port</label><input id="invite-tcp-port" type="number" placeholder="5105" class="form-input" /></div>
            <div><label class="form-label">Web Port</label><input id="invite-web-port" type="number" placeholder="3105" class="form-input" /></div>
          </div>
        </div>
        <div class="modal-foot">
          <button class="btn-modal-cancel" data-modal="modal-invite-peer">Hủy</button>
          <button id="confirm-invite-peer" class="btn-modal-ok">Mời & Khởi động</button>
        </div>
      </div>
    </div>

    <div id="toast-container" class="toast-container"></div>
    <script src="/socket.io/socket.io.js"></script>
    <script src="/public/app.js" type="module"></script>
  </body>
</html>
